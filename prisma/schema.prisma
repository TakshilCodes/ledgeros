generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  displayName    String?
  hashedPassword String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  expenses          Expense[]
  budgets           Budget[]
  subscriptions     Subscription[]
  recurringExpenses RecurringExpense[]
}

model Expense {
  id        String          @id @default(uuid())
  userId    String
  name      String
  category  ExpenseCategory
  amount    Decimal
  note      String?
  spentAt   DateTime        @default(now())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, spentAt])
  @@index([userId, category])
}

enum ExpenseCategory {
  FOOD
  TRAVEL
  SHOPPING
  SUBSCRIPTION
  OTHER
}

model Budget {
  id        String           @id @default(uuid())
  userId    String
  type      BudgetType
  category  ExpenseCategory?
  amount    Decimal
  month     Int
  year      Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, month, year])
}

enum BudgetType {
  MONTHLY
  CATEGORY
  DAILY_LIMIT
}

model SubscriptionTemplate {
  id            String             @id @default(cuid())
  name          String             @unique
  logo          String?
  category      String
  plans         SubscriptionPlan[]
  subscriptions Subscription[]
}

model SubscriptionPlan {
  id           String       @id @default(cuid())
  templateId   String
  name         String
  amount       Decimal
  billingCycle BillingCycle

  template      SubscriptionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([templateId, name, billingCycle])
}

model Subscription {
  id              String        @id @default(cuid())
  userId          String
  templateId      String?
  planId          String?

  name            String
  planName        String?
  category        String

  amount          Decimal
  billingCycle    BillingCycle
  nextRenewalDate DateTime
  isActive        Boolean       @default(true)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  template SubscriptionTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  plan     SubscriptionPlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, nextRenewalDate])
  @@index([userId, category])
  @@index([templateId])
  @@index([planId])
}

model RecurringExpense {
  id           String            @id @default(cuid())
  userId       String
  name         String
  amount       Decimal
  category     RecurringCategory
  billingCycle BillingCycle
  nextDueDate  DateTime
  note         String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, nextDueDate])
  @@index([userId, category])
  @@index([userId, isActive])
}

enum RecurringCategory {
  HOUSING
  UTILITIES
  EMI
  EDUCATION
  HEALTH
  INSURANCE
  INVESTMENT
  INTERNET_PHONE
  MAINTENANCE
  OTHER
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

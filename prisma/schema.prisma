generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  displayName    String?
  hashedPassword String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  expenses          Expense[]
  budgets           Budget[]
  subscriptions     Subscription[]
  recurringExpenses RecurringExpense[]
}

model Expense {
  id        String          @id @default(uuid())
  userId    String
  name      String
  category  ExpenseCategory
  amount    Decimal
  note      String?
  spentAt   DateTime        @default(now())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, spentAt])
  @@index([userId, category])
}

enum ExpenseCategory {
  FOOD
  TRAVEL
  SHOPPING
  SUBSCRIPTION
  OTHER
}

model Budget {
  id        String     @id @default(uuid())
  userId    String
  type      BudgetType
  category  ExpenseCategory?
  amount    Decimal
  month     Int
  year      Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, month, year])
}

enum BudgetType {
  MONTHLY
  CATEGORY
  DAILY_LIMIT
}

model SubscriptionTemplate {
  id       String             @id @default(cuid())
  name     String
  logo     String?
  category String
  plans    SubscriptionPlan[]
}

model SubscriptionPlan {
  id           String       @id @default(cuid())
  templateId   String
  name         String
  amount       Decimal
  billingCycle BillingCycle

  template SubscriptionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Subscription {
  id             String        @id @default(cuid())
  userId         String
  templateId     String?
  planId         String?
  name           String
  amount         Decimal
  billingCycle   BillingCycle
  nextRenewalDate DateTime
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, nextRenewalDate])
}

model RecurringExpense {
  id           String       @id @default(cuid())
  userId       String
  name         String
  amount       Decimal
  billingCycle BillingCycle
  nextDueDate  DateTime
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, nextDueDate])
}

enum BillingCycle {
  MONTHLY
  YEARLY
}